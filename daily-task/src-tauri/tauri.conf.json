{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DailyTask",
  "version": "1.0.0",
  "identifier": "com.dailytask.desktop",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "每日任务",
        "width": 420,
        "height": 600,
        "minWidth": 380,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": true,
        "alwaysOnTop": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
